//@version=6
// SuperTrend — Professional Edition v6.3  (STRATEGY version)


strategy("SuperTrend Pro v6.3", shorttitle = "STPro v6.3",
  overlay                  = true,
  format                   = format.price,
  precision                = 2,
  initial_capital          = 100000,
  default_qty_type         = strategy.fixed,
  default_qty_value        = 1,
  commission_type          = strategy.commission.percent,
  commission_value         = 0.10,
  slippage                 = 2,
  process_orders_on_close  = false,
  max_labels_count         = 500,
  max_lines_count          = 500)

// =============================================================================
// SECTION 0 - AUTO TIMEFRAME DETECTION
// =============================================================================
g_tf = "TF Auto-Adapt"

tfMode = input.string("Auto", "TF Mode",
  options = ["Auto", "Manual"], group = g_tf)

tfMins = timeframe.in_seconds() / 60

tfProfile = (tfMins >= 10080 ? "Weekly"
          : tfMins >= 1440  ? "Daily"
          : tfMins >= 240   ? "4H"
          : tfMins >= 60    ? "1H"
          : tfMins >= 15    ? "15m"
          : "5m or lower")

_autoVol(m)    => m >= 1440 ? 1.4  : m >= 240 ? 1.3  : m >= 60 ? 1.4  : m >= 15 ? 1.2  : 1.1
_autoRoc(m)    => m >= 10080? 3.0  : m >= 1440? 2.0  : m >= 240 ? 1.0 : m >= 60 ? 0.5  : m >= 15 ? 0.25 : 0.15
_autoConsec(m) => m >= 1440 ? 2    : m >= 240  ? 2   : m >= 60  ? 2   : 1
_autoAtrPct(m) => m >= 1440 ? 50.0 : m >= 240  ? 45.0: m >= 60  ? 45.0: m >= 15 ? 35.0 : 25.0
_autoAdx(m)    => m >= 240  ? 22.0 : m >= 60   ? 20.0: m >= 15  ? 18.0: 15.0

// =============================================================================
// SECTION 1 - PRIMARY SUPERTREND
// =============================================================================
g1 = "Primary SuperTrend"

Periods    = input.int(10,     "ATR Period",           group = g1, minval = 1)
src        = input.source(hl2, "Source",               group = g1)
Multiplier = input.float(3.0,  "ATR Multiplier",       group = g1, step = 0.1, minval = 0.1)
changeATR  = input.bool(true,  "Use ta.atr() method?", group = g1)
showSignals = input.bool(true, "Show Buy/Sell Labels", group = g1)

atr2 = ta.sma(ta.tr, Periods)
atr  = changeATR ? ta.atr(Periods) : atr2

up  = src - Multiplier * atr
up1 = nz(up[1], up)
up := close[1] > up1 ? math.max(up, up1) : up
dn  = src + Multiplier * atr
dn1 = nz(dn[1], dn)
dn := close[1] < dn1 ? math.min(dn, dn1) : dn

trend = 1
trend := nz(trend[1], trend)
trend := trend == -1 and close > dn1 ? 1 : trend == 1 and close < up1 ? -1 : trend

buySignal  = trend == 1  and trend[1] == -1
sellSignal = trend == -1 and trend[1] == 1

plot(trend == 1  ? up : na, "Up Trend",
  style = plot.style_linebr, linewidth = 2, color = color.new(color.green, 0))
plot(trend == -1 ? dn : na, "Down Trend",
  style = plot.style_linebr, linewidth = 2, color = color.new(color.red, 0))

g_hl = "Highlighting"
highlighting = input.bool(true, "Background Highlight?", group = g_hl)
bgcolor(highlighting and trend == 1  ? color.new(color.green, 93) : na, title = "Uptrend BG")
bgcolor(highlighting and trend == -1 ? color.new(color.red,   93) : na, title = "Downtrend BG")

// =============================================================================
// SECTION 2 - HARD GATE H1: DUAL ST AGREEMENT
// =============================================================================
g2 = "Hard Gate H1: Dual ST Agreement"

useDualST = input.bool(true,  "Enable Dual ST Gate?", group = g2)
periods2  = input.int(20,     "Slow ATR Period",       group = g2, minval = 1)
mult2     = input.float(5.0,  "Slow ATR Multiplier",   group = g2, step = 0.1)

atr_s2  = ta.atr(periods2)
up_s2   = hl2 - mult2 * atr_s2
up1_s2  = nz(up_s2[1], up_s2)
up_s2  := close[1] > up1_s2 ? math.max(up_s2, up1_s2) : up_s2
dn_s2   = hl2 + mult2 * atr_s2
dn1_s2  = nz(dn_s2[1], dn_s2)
dn_s2  := close[1] < dn1_s2 ? math.min(dn_s2, dn1_s2) : dn_s2
trend2  = 1
trend2 := nz(trend2[1], trend2)
trend2 := trend2 == -1 and close > dn1_s2 ? 1 : trend2 == 1 and close < up1_s2 ? -1 : trend2

plot(useDualST and trend2 == 1  ? up_s2 : na, "Slow ST Up",
  style = plot.style_linebr, linewidth = 1, color = color.new(color.green, 60))
plot(useDualST and trend2 == -1 ? dn_s2 : na, "Slow ST Down",
  style = plot.style_linebr, linewidth = 1, color = color.new(color.red,   60))

dualAgree     = not useDualST or trend2 == trend
confirmedBuy  = buySignal  and dualAgree
confirmedSell = sellSignal and dualAgree

// =============================================================================
// SECTION 3 - HARD GATE H2: CONSECUTIVE BAR CONFIRMATION
// =============================================================================
g_consec = "Hard Gate H2: Consecutive Bars"

useConsec = input.bool(true, "Enable Consecutive Bar Gate?", group = g_consec)
manConsec = input.int(2,     "Manual Bars Required",         group = g_consec, minval = 1, maxval = 5)

consecBars = tfMode == "Manual" ? manConsec : _autoConsec(tfMins)

var int consecCount = 0
if trend != trend[1]
    consecCount := 1
else
    consecCount := ((trend == 1  and close > close[1]) ? consecCount + 1
                 : (trend == -1 and close < close[1]) ? consecCount + 1
                 : consecCount)

consecOk    = not useConsec or consecCount >= consecBars
hardGatesOk = dualAgree and consecOk

// =============================================================================
// SECTION 4 - SOFT SCORE FILTERS
// =============================================================================
g_soft = "Soft Score Settings"
// [WR-6] Auto soft score: 1H+ needs 3/5 (quality), 15m/5m needs 2/5 (more signals)
// Override with Manual TF mode if you want a fixed value
_autoSoftReq(m) => m >= 60 ? 3 : 2
softRequiredMan = input.int(3, "Manual: Soft filters required (out of 5)",
  group = g_soft, minval = 1, maxval = 5)
softRequired = tfMode == "Manual" ? softRequiredMan : _autoSoftReq(tfMins)

// S1: ADX
g3 = "Soft S1: ADX"
useADX    = input.bool(true,  "Include ADX?",          group = g3)
adxLen    = input.int(14,     "ADX Length",             group = g3, minval = 1)
manAdxThr = input.float(20.0, "Manual ADX Threshold",   group = g3, step = 1.0)
[_, _, adxVal] = ta.dmi(adxLen, adxLen)
adxThresh = tfMode == "Manual" ? manAdxThr : _autoAdx(tfMins)
s1_adx    = not useADX or adxVal > adxThresh

// S2: Volume
g_vol = "Soft S2: Volume Surge"
useVolFilter = input.bool(true,  "Include Volume Surge?",  group = g_vol)
volLookback  = input.int(20,     "Volume Avg Length",       group = g_vol, minval = 1)
manVolMult   = input.float(1.4,  "Manual Min Volume x avg", group = g_vol, step = 0.05)
avgVol  = ta.sma(volume, volLookback)
volMult = tfMode == "Manual" ? manVolMult : _autoVol(tfMins)
s2_vol  = not useVolFilter or volume > avgVol * volMult
barcolor(useVolFilter and volume > avgVol * volMult ? color.new(color.yellow, 80) : na,
  title = "Volume Surge Bar")

// S3: ATR percentile
g_atrpct = "Soft S3: ATR Percentile"
useATRpct = input.bool(true,  "Include ATR Percentile?", group = g_atrpct)
atrPctLen = input.int(100,    "ATR History (bars)",       group = g_atrpct, minval = 10)
manAtrPct = input.float(45.0, "Manual Min ATR %",         group = g_atrpct, step = 5.0, minval = 0.0, maxval = 100.0)
atrHigh   = ta.highest(atr, atrPctLen)
atrLow    = ta.lowest(atr,  atrPctLen)
atrRange  = atrHigh - atrLow
atrPct    = atrRange > 0 ? (atr - atrLow) / atrRange * 100 : 50.0
atrPctThr = tfMode == "Manual" ? manAtrPct : _autoAtrPct(tfMins)
s3_atr    = not useATRpct or atrPct >= atrPctThr

// S4: ROC
g_roc = "Soft S4: Rate of Change"
useROC    = input.bool(true,  "Include ROC?",       group = g_roc)
rocLen    = input.int(3,      "ROC Lookback (bars)", group = g_roc, minval = 1)
manRocThr = input.float(2.0,  "Manual Min Move %",   group = g_roc, step = 0.05)
rocVal    = math.abs(ta.roc(close, rocLen))
rocThresh = tfMode == "Manual" ? manRocThr : _autoRoc(tfMins)
s4_roc    = not useROC or rocVal >= rocThresh

// S5: BB squeeze
g_bb = "Soft S5: BB Squeeze"
useBBsqueeze = input.bool(true, "Include BB Squeeze?",  group = g_bb)
bbLen        = input.int(20,    "BB Length",             group = g_bb, minval = 1)
bbMult_in    = input.float(2.0, "BB Multiplier",         group = g_bb, step = 0.1)
squeezeLen   = input.int(10,    "Squeeze Lookback",      group = g_bb, minval = 1)
bbBasis     = ta.sma(close, bbLen)
bbUpper     = bbBasis + bbMult_in * ta.stdev(close, bbLen)
bbLower     = bbBasis - bbMult_in * ta.stdev(close, bbLen)
bbWidth     = bbUpper - bbLower
bbMinWidth  = ta.lowest(bbWidth, squeezeLen)
inSqueeze   = bbWidth <= bbMinWidth * 1.05
bbExpanding = bbWidth > bbWidth[1]
var bool wasSqueezing = false
wasSqueezing := inSqueeze ? true : bbExpanding ? false : wasSqueezing
s5_bb = not useBBsqueeze or (wasSqueezing and bbExpanding)
bgcolor(useBBsqueeze and inSqueeze ? color.new(color.blue, 95) : na, title = "BB Squeeze Zone")

// Soft score
softScore = ((s1_adx ? 1 : 0) + (s2_vol ? 1 : 0) + (s3_atr ? 1 : 0) +
             (s4_roc ? 1 : 0) + (s5_bb  ? 1 : 0))
softOk    = softScore >= softRequired

// =============================================================================
// =============================================================================
// SECTION 4b - HARD GATE H3: HIGHER TIMEFRAME TREND FILTER  [HTF]
// =============================================================================
// Prevents counter-trend trades — biggest cause of losing signals on 15m/1H.
// Before any Buy is allowed, the HTF SuperTrend must be bullish.
// Before any Sell is allowed, the HTF SuperTrend must be bearish.
// Default HTF for 15m = Daily. For 1H = Daily. For 5m = 1H.
g_htf = "HTF Trend Filter"
useHTF   = input.bool(true, "Enable HTF Trend Filter?", group = g_htf,
  tooltip = "Blocks counter-trend trades. Most important filter for 15m and 1H.")
htfRes   = input.timeframe("D", "HTF Timeframe (D=Daily, 240=4H, 60=1H)", group = g_htf)
htfMult  = input.float(3.0, "HTF ATR Multiplier", group = g_htf, step = 0.1, minval = 0.1)
htfPer   = input.int(10,    "HTF ATR Period",      group = g_htf, minval = 1)

// Compute SuperTrend on the HTF using request.security
htf_close = request.security(syminfo.tickerid, htfRes, close, lookahead = barmerge.lookahead_off)
htf_hl2   = request.security(syminfo.tickerid, htfRes, hl2,   lookahead = barmerge.lookahead_off)
htf_atr   = request.security(syminfo.tickerid, htfRes, ta.atr(htfPer), lookahead = barmerge.lookahead_off)

htf_up    = htf_hl2 - htfMult * htf_atr
htf_up1   = nz(htf_up[1], htf_up)
htf_up   := htf_close[1] > htf_up1 ? math.max(htf_up, htf_up1) : htf_up
htf_dn    = htf_hl2 + htfMult * htf_atr
htf_dn1   = nz(htf_dn[1], htf_dn)
htf_dn   := htf_close[1] < htf_dn1 ? math.min(htf_dn, htf_dn1) : htf_dn
htf_trend = 1
htf_trend := nz(htf_trend[1], htf_trend)
htf_trend := htf_trend == -1 and htf_close > htf_dn1 ? 1 : htf_trend == 1 and htf_close < htf_up1 ? -1 : htf_trend

// HTF gate: buy only when HTF bullish, sell only when HTF bearish
htfBullish = not useHTF or htf_trend == 1
htfBearish = not useHTF or htf_trend == -1

// Plot HTF ST level as a thick line for visual reference
plot(useHTF and htf_trend == 1  ? htf_up : na, "HTF ST Bull", color = color.new(color.green, 40), linewidth = 3, style = plot.style_linebr)
plot(useHTF and htf_trend == -1 ? htf_dn : na, "HTF ST Bear", color = color.new(color.red,   40), linewidth = 3, style = plot.style_linebr)

// SECTION 5 - FINAL SIGNAL
// =============================================================================
// [HTF] Buy only when HTF trend is bullish; Sell only when HTF trend is bearish
validBuy  = confirmedBuy  and hardGatesOk and softOk and htfBullish
validSell = confirmedSell and hardGatesOk and softOk and htfBearish

plotshape(showSignals and validBuy  ? up : na, "Buy Label",
  text = "Buy", location = location.absolute, style = shape.labelup,
  size = size.small, color = color.new(color.green, 0), textcolor = color.white)
plotshape(showSignals and validSell ? dn : na, "Sell Label",
  text = "Sell", location = location.absolute, style = shape.labeldown,
  size = size.small, color = color.new(color.red, 0), textcolor = color.white)

// Near miss — hard gates passed but score not enough
plotshape((confirmedBuy  and hardGatesOk and not softOk) ? up : na, "Near Miss Buy",
  location = location.absolute, style = shape.xcross,
  size = size.tiny, color = color.new(color.gray, 20))
plotshape((confirmedSell and hardGatesOk and not softOk) ? dn : na, "Near Miss Sell",
  location = location.absolute, style = shape.xcross,
  size = size.tiny, color = color.new(color.gray, 20))

// =============================================================================
// SECTION 6 - EXIT SETTINGS
// =============================================================================
g_exit = "Exit Settings"

exitMode = input.string("C", "Exit Mode",  // [WR-2] B→C: trailing stop lets IOC's big swings run
  options = ["A", "B", "C"],
  group   = g_exit,
  tooltip = "A = ATR SL + ATR TP (fixed levels). B = ATR SL + Profit % target. C = ATR SL + Trailing stop.")

slMult = input.float(1.5, "Stop Loss (x ATR)",
  group = g_exit, step = 0.25, minval = 0.25,
  tooltip = "SL distance = ATR at entry x this multiplier. Used in all three exit modes.")

tpMult = input.float(3.0, "Mode A: Take Profit (x ATR)",
  group = g_exit, step = 0.25, minval = 0.25,
  tooltip = "TP distance = ATR at entry x this multiplier. Only used in Mode A.")

profitPct = input.float(3.0, "Mode B: Profit % Target",
  group = g_exit, step = 0.25, minval = 0.1,
  tooltip = "Exit when unrealized profit reaches this %. e.g. 3.0 = exit when up 3% from entry price.")

trailMult = input.float(1.5, "Mode C: Trail Distance (x ATR)",
  group = g_exit, step = 0.25, minval = 0.25,
  tooltip = "Trailing stop follows price by ATR x this multiplier once in profit.")

// Risk-based position sizing
g_risk  = "Position Sizing"
riskPct = input.float(1.0, "Risk per Trade (% of equity)",
  group = g_risk, step = 0.25, minval = 0.1, maxval = 10.0,
  tooltip = "SL hit = exactly this % of current equity lost. Standard is 1-2%.")

// [FIX-3] Guard posSize: if ATR not yet warmed up, default to 1 lot
//         Prevents an enormous first position during the Periods warm-up bars
slDist  = atr * slMult
posSize = (na(atr) or slDist <= 0)
  ? 1
  : math.max(1, math.floor(
      (strategy.equity * riskPct / 100) / (slDist * syminfo.pointvalue)))

// =============================================================================
// SECTION 7 - STRATEGY EXECUTION
// =============================================================================
// Entry
if validBuy
    strategy.entry("Long", strategy.long, qty = posSize, comment = "BUY")
if validSell
    strategy.entry("Short", strategy.short, qty = posSize, comment = "SELL")

// Close on opposite signal — explicit close before new entry
// keeps trade history clean and avoids any broker-adapter ambiguity
if validSell and strategy.position_size > 0
    strategy.close("Long", comment = "Flip->Short")
if validBuy  and strategy.position_size < 0
    strategy.close("Short", comment = "Flip->Long")

// [FIX-2] Anchor SL/TP to actual fill price (entry_price) not signal-bar close
//         With process_orders_on_close=false the fill is intrabar, so close
//         of the signal bar ≠ fill price. Using entry_price(0) is accurate.
//         We still snapshot ATR at signal bar (frozen var) for the distance,
//         but shift the anchor to the real fill price.
//
//         Pattern:
//           • On signal bar:  store the ATR-based distances (atrDist vars)
//           • Every bar in position: recompute levels from live entry_price(0)
//             combined with the frozen distances
//
var float frozenSlDist = na   // ATR distance frozen at entry signal bar
var float frozenTpDist = na   // ATR TP distance (Mode A) frozen at entry signal bar
var float frozenTrail  = na   // Trail points frozen at entry signal bar

if validBuy or validSell
    frozenSlDist := atr * slMult
    frozenTpDist := atr * tpMult
    frozenTrail  := math.round(atr * trailMult / syminfo.mintick)

// Compute live SL/TP levels using actual fill price + frozen ATR distances
entryPx   = strategy.opentrades > 0 ? strategy.opentrades.entry_price(0) : na

fixedLongSL  = not na(entryPx) ? entryPx - frozenSlDist : na
fixedShortSL = not na(entryPx) ? entryPx + frozenSlDist : na

fixedLongTP  = (exitMode == "A" and not na(entryPx)) ? entryPx + frozenTpDist
             : (exitMode == "B" and not na(entryPx)) ? entryPx * (1 + profitPct / 100)
             : na

fixedShortTP = (exitMode == "A" and not na(entryPx)) ? entryPx - frozenTpDist
             : (exitMode == "B" and not na(entryPx)) ? entryPx * (1 - profitPct / 100)
             : na

// Long exits
if strategy.position_size > 0
    if exitMode == "A"
        strategy.exit("Long Exit", "Long",
          stop           = fixedLongSL,
          limit          = fixedLongTP,
          comment_loss   = "SL",
          comment_profit = "TP")
    else if exitMode == "B"
        strategy.exit("Long Exit", "Long",
          stop           = fixedLongSL,
          limit          = fixedLongTP,
          comment_loss   = "SL",
          comment_profit = str.tostring(profitPct) + "% TP")
    else
        strategy.exit("Long Exit", "Long",
          stop           = fixedLongSL,
          trail_points   = frozenTrail,
          trail_offset   = frozenTrail,
          comment_loss   = "SL",
          comment_profit = "Trail")

// Short exits
if strategy.position_size < 0
    if exitMode == "A"
        strategy.exit("Short Exit", "Short",
          stop           = fixedShortSL,
          limit          = fixedShortTP,
          comment_loss   = "SL",
          comment_profit = "TP")
    else if exitMode == "B"
        strategy.exit("Short Exit", "Short",
          stop           = fixedShortSL,
          limit          = fixedShortTP,
          comment_loss   = "SL",
          comment_profit = str.tostring(profitPct) + "% TP")
    else
        strategy.exit("Short Exit", "Short",
          stop           = fixedShortSL,
          trail_points   = frozenTrail,
          trail_offset   = frozenTrail,
          comment_loss   = "SL",
          comment_profit = "Trail")

// =============================================================================
// SECTION 8 - SL / TP LINES ON CHART
// =============================================================================
showLevels = input.bool(true, "Show SL / TP Lines?", group = g_exit)

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0

activeSL = inLong  ? fixedLongSL  : inShort ? fixedShortSL : na
activeTP = inLong  ? fixedLongTP  : inShort ? fixedShortTP : na

plot(showLevels ? activeSL : na, "Stop Loss",
  color = color.new(color.red,   0), linewidth = 1, style = plot.style_linebr)
plot(showLevels ? activeTP : na, "Take Profit",
  color = color.new(color.green, 0), linewidth = 1, style = plot.style_linebr)

// =============================================================================
// SECTION 9 - BARS-IN-TREND COUNTER
// =============================================================================
showBarsHeld = input.bool(true, "Show Bars-in-Trend Label?", group = "Labels")

var int barsInTrend = 0
barsInTrend := trend == trend[1] ? barsInTrend + 1 : 1

if showBarsHeld and barstate.islastconfirmedhistory
    labelY     = trend == 1 ? up - atr * 0.5 : dn + atr * 0.5
    labelStyle = trend == 1 ? label.style_label_up : label.style_label_down
    labelColor = trend == 1 ? color.new(color.green, 20) : color.new(color.red, 20)
    label.new(bar_index, labelY,
      text      = str.tostring(barsInTrend) + " bars",
      color     = labelColor,
      textcolor = color.white,
      style     = labelStyle,
      size      = size.small)

// =============================================================================
// SECTION 10 - LIVE DASHBOARD
// =============================================================================
g_dash   = "Dashboard"
showDash = input.bool(true, "Show Dashboard?", group = g_dash)
dashPos  = input.string("Top Right", "Position",
  options = ["Top Right", "Bottom Right", "Bottom Left"], group = g_dash)

// [DASH-FIX-1] Do NOT use `var` for dp — var freezes the value on bar 0 before
//              inputs are fully resolved. Compute position fresh every bar.
// [DASH-FIX-2] Do NOT wrap table.cell() in a helper function — Pine closures
//              capture `dash` by reference at definition time (when it is still na),
//              so cells written via _c() silently fail. Write table.cell() inline.

_hdr = color.new(#1e222d, 0)
_row = color.new(#2a2e39, 0)
_wht = color.white
_grn = color.new(color.green, 20)
_red = color.new(color.red,   20)
_gry = color.new(color.gray,  20)
_ylw = color.new(color.yellow,20)
_cyn = color.new(color.aqua,  20)
_orn = color.new(color.orange,20)

_pass(ok)    => ok ? _grn : _red
_passStr(ok) => ok ? "PASS" : "FAIL"

var table dash = na

if barstate.islast and showDash
    // Resolve position fresh — never freeze with var
    dashPosVal = (dashPos == "Bottom Left"  ? position.bottom_left
               : dashPos == "Bottom Right" ? position.bottom_right
               : position.top_right)

    // Recreate table if missing (e.g. showDash was toggled off→on)
    if na(dash)
        dash := table.new(dashPosVal, 2, 23,
          bgcolor      = _hdr,
          border_color = color.new(color.gray, 60), border_width = 1,
          frame_color  = color.new(color.gray, 50), frame_width  = 1)

    // ── build display strings ──────────────────────────────────────────────
    trendTxt  = trend == 1 ? "LONG" : "SHORT"
    trendCol  = trend == 1 ? _grn   : _red
    dualTxt   = useDualST ? (dualAgree ? "AGREE" : "DISAGREE") : "OFF"
    dualCol   = useDualST ? (dualAgree ? _grn    : _red)       : _gry
    consecTxt = str.tostring(consecCount) + "/" + str.tostring(consecBars) + "  " + _passStr(consecOk)
    scoreTxt  = str.tostring(softScore) + "/" + str.tostring(softRequired) + " needed"
    scoreCol  = softScore >= softRequired ? _grn : softScore >= softRequired - 1 ? _ylw : _red
    tfRowTxt  = tfProfile + (tfMode == "Auto" ? " (auto)" : " (manual)")
    threshTxt = "V:" + str.tostring(math.round(volMult, 2)) + " R:" + str.tostring(math.round(rocThresh, 2)) + " C:" + str.tostring(consecBars) + " A:" + str.tostring(math.round(atrPctThr, 0)) + "%" + " D:" + str.tostring(math.round(adxThresh, 0))
    exitModeTxt = exitMode == "A" ? "ATR TP (" + str.tostring(tpMult) + "x)" : exitMode == "B" ? "Profit % (" + str.tostring(profitPct) + "%)" : "Trailing (" + str.tostring(trailMult) + "x)"

    openPnlPct = strategy.position_size != 0 and not na(entryPx) ? (strategy.position_size > 0 ? (close - entryPx) / entryPx * 100 : (entryPx - close) / entryPx * 100) : 0.0
    pnlTxt  = strategy.position_size != 0 ? str.tostring(math.round(openPnlPct, 2)) + "%" : "FLAT"
    pnlCol  = strategy.position_size == 0 ? _gry : openPnlPct >= 0 ? _grn : _red

    netPnlPct = math.round(strategy.netprofit / strategy.initial_capital * 100, 2)
    pf        = strategy.grossloss != 0
              ? math.round(strategy.grossprofit / math.abs(strategy.grossloss), 2)
              : 0.0
    winPct    = strategy.closedtrades > 0
              ? math.round(strategy.wintrades / strategy.closedtrades * 100, 1)
              : 0.0

    slTxt  = not na(activeSL) ? str.tostring(math.round_to_mintick(activeSL)) : "n/a"
    tpTxt  = not na(activeTP) ? str.tostring(math.round_to_mintick(activeTP)) : "n/a"

    sigTxt = validBuy    ? "BUY VALID"
           : validSell   ? "SELL VALID"
           : (confirmedBuy or confirmedSell) and hardGatesOk ? "NEAR MISS"
           : trend == 1  ? "IN LONG" : "IN SHORT"
    sigCol = validBuy or validSell                                    ? _grn
           : (confirmedBuy or confirmedSell) and hardGatesOk          ? _ylw
           : _row

    bbStateTxt = inSqueeze ? "SQUEEZE" : bbExpanding ? "EXPND" : "NORMAL"
    bbStateCol = s5_bb ? _grn : inSqueeze ? _ylw : _red

    // ── write cells inline (no helper function — avoids closure/na bug) ────
    table.cell(dash, 0,  0, "Metric",           bgcolor = _hdr, text_color = _wht, text_size = size.small)
    table.cell(dash, 1,  0, "Value",            bgcolor = _hdr, text_color = _wht, text_size = size.small)
    table.cell(dash, 0,  1, "TF profile",       bgcolor = _cyn, text_color = _wht, text_size = size.small)
    table.cell(dash, 1,  1, tfRowTxt,           bgcolor = _cyn, text_color = _wht, text_size = size.small)
    table.cell(dash, 0,  2, "Thresholds",       bgcolor = _cyn, text_color = _wht, text_size = size.small)
    table.cell(dash, 1,  2, threshTxt,          bgcolor = _cyn, text_color = _wht, text_size = size.small)
    table.cell(dash, 0,  3, "Exit mode",        bgcolor = _cyn, text_color = _wht, text_size = size.small)
    table.cell(dash, 1,  3, exitModeTxt,        bgcolor = _cyn, text_color = _wht, text_size = size.small)
    table.cell(dash, 0,  4, "ST Trend",         bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1,  4, trendTxt,           bgcolor = trendCol, text_color = _wht, text_size = size.small)
    table.cell(dash, 0,  5, "H1 Dual ST",       bgcolor = _orn, text_color = _wht, text_size = size.small)
    table.cell(dash, 1,  5, dualTxt,            bgcolor = dualCol,  text_color = _wht, text_size = size.small)
    table.cell(dash, 0,  6, "H2 Consec",        bgcolor = _orn, text_color = _wht, text_size = size.small)
    table.cell(dash, 1,  6, consecTxt,          bgcolor = _pass(consecOk), text_color = _wht, text_size = size.small)
    htfTxt = useHTF ? (htf_trend == 1 ? "BULL (" + htfRes + ")" : "BEAR (" + htfRes + ")") : "OFF"
    htfCol = useHTF ? (htf_trend == 1 ? _grn : _red) : _gry
    table.cell(dash, 0,  7, "H3 HTF",           bgcolor = _orn, text_color = _wht, text_size = size.small)
    table.cell(dash, 1,  7, htfTxt,             bgcolor = htfCol, text_color = _wht, text_size = size.small)
    table.cell(dash, 0,  8, "Soft score",       bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1,  8, scoreTxt,           bgcolor = scoreCol, text_color = _wht, text_size = size.small)
    table.cell(dash, 0,  9, "S1 ADX",           bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1,  9, str.tostring(math.round(adxVal, 1)),            bgcolor = _pass(s1_adx), text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 10, "S2 Volume",        bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 10, str.tostring(math.round(volume / avgVol, 2)) + "x", bgcolor = _pass(s2_vol), text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 11, "S3 ATR%",          bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 11, str.tostring(math.round(atrPct, 1)) + "%",     bgcolor = _pass(s3_atr), text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 12, "S4 ROC",           bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 12, str.tostring(math.round(rocVal, 2)) + "%",     bgcolor = _pass(s4_roc), text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 13, "S5 BB",            bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 13, bbStateTxt,         bgcolor = bbStateCol, text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 14, "Open P&L",         bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 14, pnlTxt,             bgcolor = pnlCol,   text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 15, "SL / TP",          bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 15, slTxt + " / " + tpTxt, bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 16, "Bars held",        bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 16, str.tostring(barsInTrend), bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 17, "Signal",           bgcolor = _hdr, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 17, sigTxt,             bgcolor = sigCol,   text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 18, "--- Backtest ---", bgcolor = _hdr, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 18, "Results",          bgcolor = _hdr, text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 19, "Net P&L",          bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 19, str.tostring(netPnlPct) + "%",
      bgcolor = netPnlPct >= 0 ? _grn : _red, text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 20, "Profit factor",    bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 20, str.tostring(pf),
      bgcolor = pf >= 1.5 ? _grn : pf >= 1.0 ? _ylw : _red, text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 21, "Win rate",         bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 21, str.tostring(winPct) + "% (" + str.tostring(strategy.wintrades) + "/" + str.tostring(strategy.closedtrades) + ")",
      bgcolor = winPct >= 50 ? _grn : winPct >= 35 ? _ylw : _red, text_color = _wht, text_size = size.small)
    table.cell(dash, 0, 22, "Max drawdown",     bgcolor = _row, text_color = _wht, text_size = size.small)
    table.cell(dash, 1, 22, str.tostring(math.round(strategy.max_drawdown_percent, 1)) + "%",
      bgcolor = strategy.max_drawdown_percent < 10 ? _grn
              : strategy.max_drawdown_percent < 20 ? _ylw : _red,
      text_color = _wht, text_size = size.small)

// =============================================================================
// SECTION 11 - ALERTS
// =============================================================================
_scoreStr() =>
    "Score:" + str.tostring(softScore) + "/" + str.tostring(softRequired) + " Mode:" + exitMode

if validBuy
    alert("ST Pro BUY | " + syminfo.ticker + " [" + tfProfile + "] @ " + str.tostring(math.round_to_mintick(close)) + " | SL: " + str.tostring(math.round_to_mintick(close - atr * slMult)) + " | TP: " + (exitMode == "B" ? str.tostring(math.round_to_mintick(close * (1 + profitPct / 100))) + " (" + str.tostring(profitPct) + "%)" : str.tostring(math.round_to_mintick(close + atr * tpMult))) + " | " + _scoreStr(),
      alert.freq_once_per_bar)

if validSell
    alert("ST Pro SELL | " + syminfo.ticker + " [" + tfProfile + "] @ " + str.tostring(math.round_to_mintick(close)) + " | SL: " + str.tostring(math.round_to_mintick(close + atr * slMult)) + " | TP: " + (exitMode == "B" ? str.tostring(math.round_to_mintick(close * (1 - profitPct / 100))) + " (" + str.tostring(profitPct) + "%)" : str.tostring(math.round_to_mintick(close - atr * tpMult))) + " | " + _scoreStr(),
      alert.freq_once_per_bar)

if validBuy
    alert('{"action":"buy","ticker":"' + syminfo.ticker + '","tf":"' + tfProfile + '","price":"' + str.tostring(math.round_to_mintick(close)) + '","sl":"' + str.tostring(math.round_to_mintick(close - atr * slMult)) + '","mode":"' + exitMode + '"}',
      alert.freq_once_per_bar)

if validSell
    alert('{"action":"sell","ticker":"' + syminfo.ticker + '","tf":"' + tfProfile + '","price":"' + str.tostring(math.round_to_mintick(close)) + '","sl":"' + str.tostring(math.round_to_mintick(close + atr * slMult)) + '","mode":"' + exitMode + '"}',
      alert.freq_once_per_bar)
