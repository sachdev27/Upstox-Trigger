# ── Upstox API Credentials ──────────────────────────
API_VERSION="2.0"
API_KEY="your-api-key-here"
API_SECRET="your-api-secret-here"
REDIRECT_URI="http://localhost:8210/callback/"
AUTH_CODE=""
ACCESS_TOKEN=""
ALGO_NAME=""
ALGO_ID=""
ORDER_API_VERSION="3.0"
REQUIRE_ALGO_NAME_FOR_LIVE_ORDERS=True
AUTO_SLICE_ORDERS=True
DEFAULT_MARKET_PROTECTION=-1

# ── Network / Proxy (optional) ─────────────────────
# Upstox SDK proxy URL (used by upstox_client Configuration.proxy)
# Prefer HTTP proxy endpoint if your VM exposes one (example: 3proxy http port).
# UPSTOX_PROXY_URL="http://user:pass@140.245.243.157:3128"
# Set True to fail fast whenever live Upstox calls are attempted without a proxy.
# REQUIRE_UPSTOX_PROXY=True
# Set True only if you explicitly want global env proxy vars (can break SDK WebSocket streamers with some SOCKS schemes).
# APPLY_PROCESS_PROXY_ENV=False

# Direct requests() proxies (for diagnostics or custom HTTP calls)
# REQUESTS_HTTP_PROXY="socks5h://user:pass@140.245.243.157:1080"
# REQUESTS_HTTPS_PROXY="socks5h://user:pass@140.245.243.157:1080"

# ── Instrument Shortcuts ────────────────────────────
BANKNIFTY="NSE_INDEX|Nifty Bank"
NIFTY="NSE_INDEX|Nifty 50"

# ── Database ────────────────────────────────────────
# Set True to make .env values override DB config_settings at runtime.
# ENV_OVERRIDE_DB=False
# DATABASE_URL="sqlite:///./data/trading.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/trading"

# ── Server ──────────────────────────────────────────
# HOST="0.0.0.0"
# PORT=8000
# DEBUG=True
# LOG_LEVEL="INFO"

# ── Risk Management ────────────────────────────────
# MAX_RISK_PER_TRADE_PCT=1.0
# MAX_DAILY_LOSS_PCT=3.0
# MAX_CONCURRENT_POSITIONS=5
# SQUARE_OFF_TIME="15:15"

# ── Notifications (optional) ───────────────────────
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
